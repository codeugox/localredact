  },
  "devDependencies": {
    "@preact/preset-vite": "2.9.4",
    "@types/node": "22.14.0",
    "jsdom": "26.0.0",
    "typescript": "5.8.3",
    "vite": "6.3.2",
    "vitest": "3.1.1"
  }
